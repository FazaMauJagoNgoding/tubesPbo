# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# Firebase backend yang sama dengan aplikasi Java.
VITE_FIREBASE_API_KEY="web-api-key-firebase"
VITE_FIREBASE_DATABASE_URL="https://project-id-default-rtdb.asia-southeast1.firebasedatabase.app"

# Server-side email provider for /api/send-new-book-email.
# Configure these in Vercel Project Settings, not in frontend code.
BREVO_API_KEY=""
EMAIL_FROM="noreply@your-domain.com"
EMAIL_FROM_NAME="CampusLib"
